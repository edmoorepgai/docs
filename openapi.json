{
  "openapi": "3.0.0",
  "info": {
    "title": "PG:AI Public API",
    "version": "1.0.0",
    "description": "Public API for accessing PG:AI account intelligence data. All endpoints require API key authentication via the `x-api-key` header.",
    "contact": {
      "name": "PG:AI Support",
      "url": "https://www.getpg.ai"
    }
  },
  "servers": [
    {
      "url": "https://api.getpg.ai/public-api/v1",
      "description": "Production"
    }
  ],
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Your PG:AI API key. Generate one from Settings → API Keys in the PG:AI dashboard."
      }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "description": "Human-readable error message"
          }
        },
        "required": ["error"]
      },
      "ValidationError": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Validation error"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "example": ["Missing required field: \"last_name\"", "Missing required field: \"email\""]
          }
        },
        "required": ["error", "details"]
      },
      "Account": {
        "type": "object",
        "description": "A company/account in your PG:AI workspace",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique company identifier"
          },
          "company_name": {
            "type": "string",
            "description": "Company name"
          },
          "website_domain": {
            "type": "string",
            "description": "Primary website domain"
          },
          "public_company": {
            "type": "boolean",
            "description": "Whether the company is publicly traded"
          },
          "country_code": {
            "type": "string",
            "description": "ISO country code (e.g. US, GB)",
            "nullable": true
          },
          "linkedin_url": {
            "type": "string",
            "format": "uri",
            "description": "LinkedIn company page URL",
            "nullable": true
          },
          "hq_city": {
            "type": "string",
            "nullable": true
          },
          "hq_state": {
            "type": "string",
            "nullable": true
          },
          "hq_address": {
            "type": "string",
            "nullable": true
          },
          "hq_postcode": {
            "type": "string",
            "nullable": true
          },
          "hq_country_name": {
            "type": "string",
            "nullable": true
          },
          "region": {
            "type": "string",
            "nullable": true
          },
          "ceo": {
            "type": "string",
            "nullable": true
          },
          "sector": {
            "type": "string",
            "nullable": true
          },
          "industry": {
            "type": "string",
            "nullable": true
          },
          "revenue_range": {
            "type": "string",
            "description": "Revenue bracket (e.g. \"$100M-$500M\")",
            "nullable": true
          },
          "employee_count_range": {
            "type": "string",
            "description": "Employee count bracket (e.g. \"1001-5000\")",
            "nullable": true
          },
          "full_time_employees": {
            "type": "integer",
            "description": "Exact full-time employee count",
            "nullable": true
          },
          "description": {
            "type": "string",
            "description": "Company description",
            "nullable": true
          },
          "stock_ticker": {
            "type": "string",
            "nullable": true
          },
          "market_cap": {
            "type": "integer",
            "nullable": true
          },
          "stock_currency": {
            "type": "string",
            "nullable": true
          },
          "stock_exchange_name": {
            "type": "string",
            "nullable": true
          },
          "alternative_domains": {
            "type": "array",
            "items": { "type": "string" },
            "nullable": true
          },
          "alternative_names": {
            "type": "array",
            "items": { "type": "string" },
            "nullable": true
          },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "nullable": true
          }
        }
      },
      "CompanyContact": {
        "type": "object",
        "description": "A contact associated with a company",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "full_name": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "current_job_title": {
            "type": "string",
            "description": "Current job title",
            "nullable": true
          },
          "linkedin_url": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "location": {
            "type": "string",
            "nullable": true
          },
          "country": {
            "type": "string",
            "nullable": true
          },
          "country_code": {
            "type": "string",
            "nullable": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          },
          "image_url": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "ContactDetail": {
        "type": "object",
        "description": "Full contact record with experience, education, and skills",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "full_name": {
            "type": "string"
          },
          "first_name": {
            "type": "string"
          },
          "last_name": {
            "type": "string"
          },
          "current_job_title": {
            "type": "string",
            "nullable": true
          },
          "linkedin_url": {
            "type": "string",
            "format": "uri",
            "nullable": true
          },
          "location": {
            "type": "string",
            "nullable": true
          },
          "country": {
            "type": "string",
            "nullable": true
          },
          "headline": {
            "type": "string",
            "nullable": true
          },
          "summary": {
            "type": "string",
            "nullable": true
          },
          "emails": {
            "type": "array",
            "items": { "type": "string", "format": "email" }
          },
          "phones": {
            "type": "array",
            "items": { "type": "string" }
          },
          "skills": {
            "type": "array",
            "items": { "type": "string" }
          },
          "company": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "linkedin_id": { "type": "string" }
            },
            "nullable": true
          },
          "experience": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "job_id": { "type": "string", "format": "uuid" },
                "company_id": { "type": "string", "format": "uuid" },
                "company": { "type": "string" },
                "title": { "type": "string" },
                "location": { "type": "string", "nullable": true },
                "start_date": { "type": "string", "format": "date-time" },
                "end_date": { "type": "string", "format": "date-time", "nullable": true },
                "is_current": { "type": "boolean" }
              }
            }
          },
          "education": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "degree": { "type": "string" },
                "field_of_study": { "type": "string", "nullable": true },
                "school": { "type": "string" },
                "start_year": { "type": "integer", "nullable": true },
                "end_year": { "type": "integer", "nullable": true }
              }
            }
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          }
        }
      },
      "SwotItem": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Title of the SWOT item"
          },
          "type": {
            "type": "string",
            "enum": ["STRENGTH", "WEAKNESS", "OPPORTUNITY", "THREAT"],
            "description": "SWOT category"
          },
          "description": {
            "type": "string",
            "description": "Detailed analysis"
          }
        }
      },
      "Competitor": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "website": {
            "type": "string",
            "format": "uri"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "KeyExecutive": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "title": {
            "type": "string"
          }
        }
      },
      "ContentItem": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "content_type": {
            "type": "string",
            "description": "Type of content (e.g. email, document, call_script)"
          },
          "title": {
            "type": "string"
          },
          "content": {
            "type": "string",
            "description": "Full content body"
          }
        }
      },
      "Territory": {
        "type": "object",
        "description": "A territory in your workspace",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "territory_name": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TerritoryCompany": {
        "type": "object",
        "description": "A company assigned to a territory",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "company_id": {
            "type": "string",
            "format": "uuid"
          },
          "status": {
            "type": "string",
            "description": "Processing status (e.g. Completed, not_started)"
          },
          "created_at": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PaginatedResponse": {
        "type": "object",
        "properties": {
          "itemsReceived": { "type": "integer" },
          "curPage": { "type": "integer" },
          "nextPage": { "type": "integer", "nullable": true },
          "prevPage": { "type": "integer", "nullable": true },
          "offset": { "type": "integer" },
          "perPage": { "type": "integer" },
          "itemsTotal": { "type": "integer" },
          "pageTotal": { "type": "integer" }
        }
      }
    }
  },
  "paths": {
    "/accounts": {
      "post": {
        "summary": "Search accounts",
        "description": "Search for companies (accounts) in your workspace. Send an empty body `{}` to return all results.",
        "operationId": "searchAccounts",
        "tags": ["Companies"],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "company_name": {
                    "type": "string",
                    "description": "Filter by company name (partial match)"
                  },
                  "industry": {
                    "type": "string",
                    "description": "Filter by industry"
                  },
                  "country": {
                    "type": "string",
                    "description": "Filter by country"
                  },
                  "employee_size_category": {
                    "type": "string",
                    "description": "Filter by employee size category"
                  },
                  "revenue_category": {
                    "type": "string",
                    "description": "Filter by revenue category"
                  },
                  "public_company": {
                    "type": "boolean",
                    "description": "Filter by public company status"
                  },
                  "page": {
                    "type": "integer",
                    "default": 1
                  },
                  "per_page": {
                    "type": "integer",
                    "default": 50
                  }
                }
              },
              "example": {
                "industry": "Technology",
                "per_page": 10
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Array of matching accounts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Account"
                  }
                },
                "example": [
                  {
                    "id": "0472a8a1-bdc4-4f53-93f6-7d9a967beb76",
                    "company_name": "Sprout Social",
                    "website_domain": "sproutsocial.com",
                    "public_company": true,
                    "country_code": "US",
                    "linkedin_url": "https://www.linkedin.com/company/sprout-social-inc-",
                    "hq_city": "Chicago",
                    "hq_state": "IL",
                    "hq_country_name": "United States",
                    "ceo": "Mr. Ryan Paul Barretto",
                    "sector": "Technology",
                    "industry": "Apps",
                    "revenue_range": "$100M-$500M",
                    "employee_count_range": "1001-5000",
                    "full_time_employees": 1322,
                    "stock_ticker": "SPT",
                    "market_cap": 337111258
                  }
                ]
              }
            }
          },
          "401": {
            "description": "Invalid or missing API key",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "message": "Unauthorized" }
              }
            }
          }
        }
      }
    },
    "/companies/{company_id}": {
      "get": {
        "summary": "Get company",
        "description": "Retrieve detailed information about a specific company by its ID.",
        "operationId": "getCompany",
        "tags": ["Companies"],
        "parameters": [
          {
            "name": "company_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" },
            "description": "The unique identifier (UUID) of the company"
          }
        ],
        "responses": {
          "200": {
            "description": "Company details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Account" },
                "example": {
                  "company_id": "0472a8a1-bdc4-4f53-93f6-7d9a967beb76",
                  "company_name": "Sprout Social",
                  "website_domain": "sproutsocial.com",
                  "public_company": true,
                  "country_code": "US",
                  "linkedin_url": "https://www.linkedin.com/company/sprout-social-inc-",
                  "hq_city": "Chicago",
                  "hq_state": "IL",
                  "hq_country_name": "United States",
                  "region": "North America",
                  "ceo": "Mr. Ryan Paul Barretto",
                  "sector": "Technology",
                  "industry": "Apps",
                  "revenue_range": "$100M-$500M",
                  "employee_count_range": "1001-5000",
                  "full_time_employees": 1322,
                  "description": "Sprout Social, Inc. designs, develops, and operates a web-based social media management platform...",
                  "stock_ticker": "SPT",
                  "market_cap": 337111258,
                  "stock_currency": "USD",
                  "stock_exchange_name": "NASDAQ Capital Market"
                }
              }
            }
          },
          "400": {
            "description": "Invalid company ID format",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "Not a valid UUID." }
              }
            }
          },
          "403": {
            "description": "Company not in your workspace",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "example": { "error": "You do not have access to this company" }
              }
            }
          }
        }
      }
    },
    "/companies/{company_id}/profile": {
      "get": {
        "summary": "Get company profile",
        "description": "Retrieve a customizable company profile with selectable sections. Use the `include` parameter to request specific sections, or pass `full` to get everything.",
        "operationId": "getCompanyProfile",
        "tags": ["Companies"],
        "parameters": [
          {
            "name": "company_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "include",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated list of profile sections. Use `full` for all sections. Available: overview, key_executives, divisions, geographical_operations, swot_analysis, competitors, industry_insights, strategic_priorities, digital_strategies, risks, goals, events, value_pyramid, three_whys, discovery_questions, custom_insights, content"
          },
          {
            "name": "exclude",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated list of sections to exclude (useful with `include=full`)"
          },
          {
            "name": "sources",
            "in": "query",
            "schema": { "type": "string", "enum": ["true", "false"] },
            "description": "Set to `true` to include source citations"
          }
        ],
        "responses": {
          "200": {
            "description": "Company profile with requested sections",
            "content": {
              "application/json": {
                "example": {
                  "company_id": "0472a8a1-bdc4-4f53-93f6-7d9a967beb76",
                  "company_name": "Sprout Social",
                  "website_domain": "sproutsocial.com",
                  "hq_country_name": "United States",
                  "industry": "Apps",
                  "revenue_range": "$100M-$500M",
                  "employee_count_range": "1001-5000",
                  "overview": {
                    "public_company": true,
                    "country_code": "US",
                    "linkedin_url": "https://www.linkedin.com/company/sprout-social-inc-",
                    "hq_city": "Chicago",
                    "hq_state": "IL",
                    "region": "North America",
                    "ceo": "Mr. Ryan Paul Barretto",
                    "sector": "Technology",
                    "full_time_employees": 1322,
                    "description": "Sprout Social, Inc. designs, develops, and operates a web-based social media management platform..."
                  },
                  "swot_analysis": [
                    {
                      "name": "AI-Powered Platform with Proprietary Trellis Agent",
                      "type": "STRENGTH",
                      "description": "Sprout Social has developed a proprietary AI agent called Trellis that transforms social data into actionable insights..."
                    },
                    {
                      "name": "Limited International Presence",
                      "type": "WEAKNESS",
                      "description": "Despite growing international revenue, Sprout Social remains heavily concentrated in the North American market..."
                    }
                  ],
                  "competitors": [
                    {
                      "name": "Hootsuite",
                      "website": "https://hootsuite.com",
                      "description": "Hootsuite is a comprehensive social media management platform..."
                    },
                    {
                      "name": "Zoho Social",
                      "website": "https://www.zoho.com/social/",
                      "description": "Zoho Social is a social media management tool..."
                    }
                  ],
                  "key_executives": [
                    {
                      "name": "Ryan Barretto",
                      "title": "Chief Executive Officer and Member of the Board of Directors"
                    },
                    {
                      "name": "Justyn Howard",
                      "title": "Executive Chair and Member of the Board of Directors"
                    }
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/companies/{company_id}/content": {
      "get": {
        "summary": "Get company content",
        "description": "Retrieve AI-generated content for a company such as emails, executive reports, and call scripts.",
        "operationId": "getCompanyContent",
        "tags": ["Companies"],
        "parameters": [
          {
            "name": "company_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          },
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string", "enum": ["email", "document", "call_script", "notes"] },
            "description": "Filter by content type"
          }
        ],
        "responses": {
          "200": {
            "description": "Array of content items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/ContentItem" }
                },
                "example": [
                  {
                    "id": "9e106d89-a191-439f-a49f-b225e8fe24fe",
                    "content_type": "document",
                    "title": "Executive Report: Accelerating Enterprise Growth with PG:AI",
                    "content": "Subject: Executive Report...\n\nOur Understanding of Your Business..."
                  },
                  {
                    "id": "3aa65f1a-8b4a-480b-a947-da49ebcb1d29",
                    "content_type": "email",
                    "title": "Accelerate Enterprise Pipeline & GTM Alignment",
                    "content": "Subject: Accelerate Enterprise Pipeline...\n\nHi {Name},\n\nIn your recent earnings call..."
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/companies/{company_id}/contacts": {
      "post": {
        "summary": "Search company contacts",
        "description": "Search and filter contacts associated with a specific company.",
        "operationId": "searchCompanyContacts",
        "tags": ["Companies"],
        "parameters": [
          {
            "name": "company_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "page": { "type": "integer", "default": 1 },
                  "per_page": { "type": "integer", "default": 25 },
                  "name": { "type": "string", "description": "Filter by name" },
                  "job_title": { "type": "string", "description": "Filter by job title" },
                  "location": { "type": "string", "description": "Filter by location" }
                }
              },
              "example": {
                "per_page": 10
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Contacts with pagination",
            "content": {
              "application/json": {
                "example": {
                  "contacts": [
                    {
                      "id": "deb3474b-5836-492c-aca4-4e0ccc8afbae",
                      "full_name": "Iain Donachie",
                      "first_name": "Iain",
                      "last_name": "Donachie",
                      "current_job_title": "Head of Gift Cards UK & Ireland, Tesco",
                      "linkedin_url": "https://www.linkedin.com/in/iain-donachie-6bb3406",
                      "location": "Edinburgh, Scotland, United Kingdom",
                      "country": "United Kingdom",
                      "country_code": "GB",
                      "image_url": "https://media.licdn.com/dms/image/...",
                      "created_at": "2026-04-01T12:47:07.324Z"
                    }
                  ],
                  "pagination": {
                    "page": 1,
                    "per_page": 10,
                    "total": 42,
                    "total_pages": 5
                  }
                }
              }
            }
          }
        }
      }
    },
    "/companies/{company_id}/technologies": {
      "post": {
        "summary": "Get company technologies",
        "description": "Retrieve the technology stack for a company with optional filtering.",
        "operationId": "getCompanyTechnologies",
        "tags": ["Companies"],
        "parameters": [
          {
            "name": "company_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "category": {
                    "type": "string",
                    "description": "Filter by technology category (e.g. IT Security, Marketing, Collaboration)"
                  },
                  "confidence": {
                    "type": "string",
                    "description": "Filter by detection confidence level"
                  },
                  "favourites": {
                    "type": "boolean",
                    "description": "Only return technologies marked as favourites"
                  },
                  "query": {
                    "type": "string",
                    "description": "Search by technology name"
                  },
                  "page": { "type": "integer", "default": 1 },
                  "per_page": { "type": "integer", "default": 100 }
                }
              },
              "example": {
                "category": "IT Security",
                "per_page": 50
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Array of technologies",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "name": { "type": "string" },
                      "category": { "type": "string" },
                      "sub_category": { "type": "string", "nullable": true },
                      "confidence": { "type": "string" }
                    }
                  }
                },
                "example": [
                  {
                    "name": "Cloudflare",
                    "category": "IT Security",
                    "sub_category": "CDN & DDoS Protection",
                    "confidence": "high"
                  },
                  {
                    "name": "CrowdStrike",
                    "category": "IT Security",
                    "sub_category": "Endpoint Security",
                    "confidence": "medium"
                  }
                ]
              }
            }
          }
        }
      }
    },
