    "/search": {
      "get": {
        "summary": "Unified search",
        "description": "Search across companies, contacts, and content in a single request. Each type is searched in parallel.",
        "operationId": "unifiedSearch",
        "tags": ["Search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Search query (minimum 1 character)"
          },
          {
            "name": "types",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Comma-separated entity types: `companies`, `contacts`, `content`. Defaults to all."
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "default": 10, "minimum": 1, "maximum": 100 },
            "description": "Maximum results per type"
          }
        ],
        "responses": {
          "200": {
            "description": "Search results grouped by type",
            "content": {
              "application/json": {
                "example": {
                  "query": "Tesco",
                  "total": 3,
                  "results": {
                    "companies": {
                      "items": [
                        {
                          "id": "304599c3-212f-4122-b84a-d655a1455d31",
                          "company_name": "Tesco",
                          "website_domain": "tesco.com"
                        }
                      ],
                      "count": 1
                    },
                    "contacts": {
                      "items": [
                        {
                          "id": "deb3474b-5836-492c-aca4-4e0ccc8afbae",
                          "full_name": "Iain Donachie",
                          "current_job_title": "Head of Gift Cards UK & Ireland, Tesco"
                        }
                      ],
                      "count": 1
                    },
                    "content": {
                      "items": [],
                      "count": 0
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Missing or invalid parameters",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Error" },
                "examples": {
                  "missing_query": {
                    "value": { "error": "Query parameter \"q\" is required and must be at least 1 character" }
                  },
                  "invalid_types": {
                    "value": { "error": "Invalid types parameter. Valid values: companies, contacts, content" }
                  }
                }
              }
            }
          }
        }
      }
    },
